apiVersion: v1
kind: Secret
metadata:
  name: ecommerce-secret
type: Opaque
stringData:
  # User DB
  USER_DB_USER: "your_user_here"
  USER_DB_PASSWORD: "your_password_here"

  # Product DB
  PRODUCT_DB_USER: "your_user_here"
  PRODUCT_DB_PASSWORD: "your_password_here"

  # Cart DB
  CART_DB_USER: "your_user_here"
  CART_DB_PASSWORD: "your_password_here"

  # Order DB
  ORDER_DB_USER: "your_user_here"
  ORDER_DB_PASSWORD: "your_password_here"

  # Payment DB
  PAYMENT_DB_USER: "your_user_here"
  PAYMENT_DB_PASSWORD: "your_password_here"

  # Notification DB
  NOTIFICATION_DB_USER: "your_user_here"
  NOTIFICATION_DB_PASSWORD: "your_password_here"

  # JWT
  JWT_SECRET: "your_jwt_secret_here"

  # Stripe
  STRIPE_SK: "your_stripe_secret_key_here"
  STRIPE_WEBHOOK_SECRET: "your_stripe_webhook_secret_here"

  # SendGrid
  SENDGRID_API_KEY: "your_sendgrid_api_key_here"

